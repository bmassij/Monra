# Optioneel: e-mail via Resend (contactformulier API)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Multi-site branding (standaard: security)
SITE_BRAND=security

# OpenRouter AI chat — key op https://openrouter.ai/keys
# Gebruik .env.local voor echte keys (nooit hier!)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Meerdere gratis modellen (comma-separated) — wisselen automatisch af
# Bij rate limit (429) probeert de volgende in de lijst
OPENROUTER_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen-2.5-72b-instruct:free,mistralai/mistral-small-3.1-24b-instruct:free,google/gemma-4-26b-a4b-it:free

# Optioneel: één model (alleen als OPENROUTER_MODELS leeg is)
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Optioneel: voor OpenRouter referer header
# NEXT_PUBLIC_SITE_URL=https://jouw-vercel-url.vercel.app

# Multi-domain: familie-banner en subsite-nav gebruiken volledige domein-URL's
# Standaard false — interne paden (/support, /belgie, …) voor lokaal dev
# NEXT_PUBLIC_USE_EXTERNAL_DOMAINS=true
